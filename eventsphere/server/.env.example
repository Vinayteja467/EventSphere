# MongoDB Connection URI (for local MongoDB, change to your Atlas URI if needed)
MONGODB_URI=mongodb://127.0.0.1:27017/eventsphere

# JWT Authentication Secrets
JWT_SECRET=eventsphere_jwt_secret_key_2026_xyz
JWT_REFRESH_SECRET=eventsphere_jwt_refresh_secret_key_2026_abc

# Cloudinary (Optional, for avatar/banner uploads)
CLOUDINARY_URL=

# Google Gemini API Key (Required for AI sponsor matching)
GEMINI_API_KEY=

# Server Port
PORT=5000

# Client Application URL (for CORS)
CLIENT_URL=http://localhost:5173
